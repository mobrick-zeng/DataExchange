# ┌─────────────────────────────────────────────────────────────────┐
# │ 正式部署範本（B）：有正式網域 — 自動 HTTPS（Let's Encrypt）        │
# └─────────────────────────────────────────────────────────────────┘
# 適用：已有網域名稱（如 mediation.example.com.tw），要對外提供 HTTPS。
# 原理：設定 DOMAIN 後，Caddy 會自動向 Let's Encrypt 申請憑證並啟用 HTTPS。
#       （詳見 docs/系統現況與執行說明.md 第六節「反向代理與 HTTP／HTTPS」）
#
# 前置作業：
#   1) 將網域 DNS「A 記錄」指向本主機的公開 IP。
#   2) 防火牆／安全群組放行「80 與 443」兩個埠（憑證申請與 HTTPS 皆需要）。
#
# 用法：複製為 .env（與 docker-compose.fullstack.yml 同目錄），填入實際值後啟動：
#   cp .env.production.domain.example .env   然後編輯 .env
#   docker compose -f docker-compose.fullstack.yml up -d --build
#   → 瀏覽器開 https://你的網域
# ⚠️ .env 內含機密，請勿提交到 git。

# ============ 必改：機密與密碼 ============

# JWT 簽章金鑰（登入權杖）。用以下指令產生長隨機值：
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_openssl_rand_base64_48

# 資料庫密碼。用以下指令產生：
#   openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_openssl_rand_base64_24

# 後台 admin 預設密碼為 Demo@1234，請於上線後第一時間更改：
#   以 admin 登入 → 使用者與權限管理 → 對自己帳號按「發重置碼」→ 用該碼設定新強密碼。
#   （種子對既有帳號不覆寫密碼，重啟不會還原。）

# ============ 網域與 HTTPS ============
# 你的正式網域（不含 http/https 前綴）。Caddy 會據此自動申請憑證並啟用 HTTPS。
DOMAIN=CHANGE_ME_your.domain.com.tw

# 前端同源來源；請填 https://你的網域。
PUBLIC_ORIGIN=https://CHANGE_ME_your.domain.com.tw

# 種子模式：demo（含 5 組示範帳號）｜production（只建 admin + 銀行主檔）
SEED_MODE=production
