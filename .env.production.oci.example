# ┌─────────────────────────────────────────────────────────────────┐
# │ 正式部署範本（A）：OCI／雲主機 — 只有公網 IP、無網域、走 HTTP      │
# └─────────────────────────────────────────────────────────────────┘
# 適用：Oracle Cloud（OCI）等「只有一組公網 IP、沒有網域名稱」的主機。
# 原因：Let's Encrypt 只發憑證給網域、不發給裸 IP，故此情境不啟用 HTTPS，改走純 HTTP。
#       （詳見 docs/系統現況與執行說明.md 第三節「方式三」白話說明）
#
# 用法：複製為 .env（與 docker-compose.fullstack.yml 同目錄），填入實際值後啟動：
#   cp .env.production.oci.example .env   然後編輯 .env
#   docker compose -f docker-compose.fullstack.yml -p dataexchange up -d --build
#   → 瀏覽器開 http://<你的公網IP>
# 註：專案名固定用 -p dataexchange（同一台機器只跑這一組，避免建到別組空殼）。
# ⚠️ .env 內含機密，請勿提交到 git。
# ⚠️ 別忘了到 OCI 安全群組／防火牆放行「80」埠。

# ============ 必改：機密與密碼 ============

# JWT 簽章金鑰（登入權杖）。用以下指令產生長隨機值：
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_openssl_rand_base64_48

# 資料庫密碼。用以下指令產生：
#   openssl rand -base64 24
DB_PASSWORD=CHANGE_ME_openssl_rand_base64_24

# 後台 admin 預設密碼為 Demo@1234，請於上線後第一時間更改：
#   以 admin 登入 → 使用者與權限管理 → 對自己帳號按「發重置碼」→ 用該碼設定新強密碼。
#   （種子對既有帳號不覆寫密碼，重啟不會還原。）

# ============ 網域與 HTTP（本情境走 HTTP，不啟用 HTTPS）============
# 只有 IP 時：DOMAIN 必須「留空」，Caddy 會綁 :80、接受任何 Host（含公網 IP），走 HTTP。
DOMAIN=

# 前端同源來源；請填你的公網 IP（http、不加 https）。
PUBLIC_ORIGIN=http://CHANGE_ME_YOUR_PUBLIC_IP

# 種子模式：demo（含 5 組示範帳號）｜production（只建 admin + 銀行主檔）
SEED_MODE=production
