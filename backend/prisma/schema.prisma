// ============================================================================
//  集中式金融資料交換平台 — 資料庫 Schema（v2，2026-07-22 重新設計）
//  設計要點：
//   - 不儲存債務人個資；案件以 (法院代碼 + 公文文號) 唯一辨識。
//   - 帳號＝email，單一所屬 bankCode；正式區需啟用碼首次登入並設密碼。
//   - 參與行合併債權容器，明細掛其下；金額於各行確認當下凍結快照。
//   - 還款依「還款計畫比例(planRatio)」攤提，尾差由最大債權行吸收。
//   - 單一 append-only 稽核；Bank/Court 參考表以 isActive 控制可用範圍。
//  金額 Decimal(21,4)；比例 Decimal(9,6)（0~1，各行加總=1，應用層驗）。
// ============================================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================== 列舉 ==============================

enum BankType {
  BANK
  PLATFORM
}

enum Role {
  ADMIN // 平台管理員
  BANK_STAFF // 銀行人員（主辦/其他債權行因案動態認定）
  PLATFORM_AUDITOR // 平台稽核（唯讀＋可見 internalTotal）
}

enum AccountStatus {
  PENDING_ACTIVATION // 正式區：已建立、待以啟用碼首次登入並設定密碼
  ACTIVE // 已啟用
  SUSPENDED // 已停用（管理員）
}

enum AccessCodePurpose {
  ACTIVATION // 帳號啟用碼（正式區首次登入用）
  PASSWORD_RESET // 密碼重置碼（管理員核發）
}

enum ResetRequestStatus {
  PENDING // 待管理員處理
  RESOLVED // 已核發重置碼
}

enum CaseStatus {
  DRAFT // 建立中（主辦代填、設定計畫比例、邀請）
  PENDING_CONFIRMATION // 已發布，待各其他債權行確認
  IN_REPAYMENT // 全數確認、方案生效，逐月攤提還款
  SETTLED // 已結清
  TERMINATED // 毀諾／終止
}

enum ParticipantConfirmationStatus {
  NOT_REQUIRED // 主辦本身
  PENDING // 待確認
  CONFIRMED // 已確認
  DISPUTED // 已回報異議
}

enum CaseBankRole {
  MAIN
  CO_BANK
}

enum ClaimType {
  CREDIT_LOAN
  CREDIT_CARD
  GUARANTEE
  OTHER
}

enum NotificationType {
  CASE_INVITATION
  CASE_PUBLISHED
  CONFIRMATION_DEADLINE_REMINDER
  CASE_CONFIRMED_BY_BANK
  CASE_DISPUTED_BY_BANK
  ALL_BANKS_CONFIRMED
  REPAYMENT_RECORDED
  CASE_SETTLED
  CASE_TERMINATED
}

enum AuditActionType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  ACCOUNT_CREATED
  ACCOUNT_ACTIVATED
  ACCOUNT_SUSPENDED
  ACCOUNT_REACTIVATED
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  CONSENT_GIVEN
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_ISSUED
  CASE_CREATED
  CASE_UPDATED
  PARTICIPANT_INVITED
  CASE_PUBLISHED
  CASE_CONFIRMED
  CASE_DISPUTED
  PLAN_RATIO_UPDATED
  REPAYMENT_RECORDED
  CASE_SETTLED
  CASE_TERMINATED
  INTERNAL_TOTAL_VIEWED
  BANK_ACTIVATED
  BANK_DEACTIVATED
  COURT_ACTIVATED
  COURT_DEACTIVATED
}

// ============================== 參考主檔 ==============================

/// 金融機構主檔（含完整代碼清單；isActive 控制可用範圍，後台可管理）
model Bank {
  bankCode String   @id // 3 碼金融機構代號（自然鍵）
  bankName String
  type     BankType @default(BANK)
  isActive Boolean  @default(false) // 僅啟用者可選/可登入

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  casesAsMain   Case[]                @relation("CaseMainBank")
  participantOf CaseParticipantBank[]

  @@index([isActive])
  @@map("banks")
}

/// 法院主檔（含完整清單；isActive 控制可用範圍，後台可管理）
model Court {
  courtCode String  @id // 法院代碼（自然鍵）
  courtName String
  courtType String? // 例：地方法院／高等法院…（選填）
  isActive  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases Case[]

  @@index([isActive])
  @@map("courts")
}

// ============================== 使用者與帳號 ==============================

/// 使用者（承辦人員）；帳號＝email，單一所屬 bankCode，角色必填
model User {
  userId       String  @id @default(cuid())
  email        String  @unique
  name         String
  department   String?
  title        String?
  passwordHash String? // 待啟用時為 null，首次以啟用碼登入後設定

  bankCode      String
  role          Role
  accountStatus AccountStatus @default(PENDING_ACTIVATION)

  activatedAt DateTime?
  lastLoginAt DateTime?

  // 個資蒐集/利用同意（啟用時強制勾選）
  consentedAt    DateTime?
  consentVersion String?

  // 登入鎖定
  failedLoginCount Int       @default(0)
  lockedUntil      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bank Bank @relation(fields: [bankCode], references: [bankCode])

  accessCodes              AccessCode[]           @relation("AccessCodeUser")
  createdAccessCodes       AccessCode[]           @relation("AccessCodeCreatedBy")
  passwordResetRequests    PasswordResetRequest[]
  createdCases             Case[]                 @relation("CaseCreatedBy")
  participantConfirmations CaseParticipantBank[]  @relation("ParticipantConfirmedBy")
  recordedPeriods          RepaymentPeriod[]      @relation("RepaymentRecordedBy")
  notifications            Notification[]
  auditLogs                AuditLog[]

  @@index([bankCode])
  @@index([accountStatus])
  @@map("users")
}

/// 一次性代碼（啟用碼／密碼重置碼）；僅存雜湊，明碼由外部管道遞送
model AccessCode {
  codeId    String            @id @default(cuid())
  userId    String
  purpose   AccessCodePurpose
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdBy String // 核發的管理員
  createdAt DateTime          @default(now())

  user    User @relation("AccessCodeUser", fields: [userId], references: [userId], onDelete: Cascade)
  creator User @relation("AccessCodeCreatedBy", fields: [createdBy], references: [userId])

  @@index([userId, purpose])
  @@map("access_codes")
}

/// 使用者申請密碼重置的佇列（供管理員檢視並核發重置碼）
model PasswordResetRequest {
  requestId  String             @id @default(cuid())
  userId     String
  status     ResetRequestStatus @default(PENDING)
  createdAt  DateTime           @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([status])
  @@map("password_reset_requests")
}

// ============================== 案件 ==============================

/// 調解案件；以 (courtCode, docNumber) 唯一辨識，不存債務人個資
model Case {
  caseId    String @id @default(cuid())
  courtCode String // 法院
  docNumber String // 法院公文文號（格式後續確認；僅作辨識，不解析）

  mainBankCode         String // 最大債權行（主辦）
  receiptDate          DateTime? // 收到公文日
  confirmationDeadline DateTime? // 各行確認期限
  status               CaseStatus @default(DRAFT)

  // 還款計畫（planRatio 放在各參與行）
  monthlyInstallment Decimal?  @db.Decimal(21, 4) // 每月應還總額
  planInstallments   Int? // 期數
  planStartDate      DateTime?

  // 全數確認時凍結的金額快照（各行加總）
  totalDebtAmount Decimal?  @db.Decimal(21, 4)
  confirmedAt     DateTime?

  settledAt         DateTime?
  terminatedAt      DateTime?
  terminationReason String?

  createdBy String
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  court    Court @relation(fields: [courtCode], references: [courtCode])
  mainBank Bank  @relation("CaseMainBank", fields: [mainBankCode], references: [bankCode])
  creator  User  @relation("CaseCreatedBy", fields: [createdBy], references: [userId])

  participants     CaseParticipantBank[]
  repaymentPeriods RepaymentPeriod[]

  @@unique([courtCode, docNumber]) // 唯一業務鍵
  @@index([status])
  @@index([mainBankCode])
  @@map("cases")
}

/// 案件參與銀行（已合併債權容器）；代理主鍵供明細外鍵使用
model CaseParticipantBank {
  participantId String       @id @default(cuid())
  caseId        String
  bankCode      String
  roleInCase    CaseBankRole
  invitedAt     DateTime     @default(now())

  // 還款計畫比例：建立案件時手動設定、與債權占比無關；發布後鎖定，僅 ADMIN 可改
  planRatio Decimal @default(0) @db.Decimal(9, 6)

  // 確認 / 異議
  confirmationStatus ParticipantConfirmationStatus @default(PENDING)
  confirmedBy        String?
  confirmedAt        DateTime?
  disputeReason      String?
  disputedAt         DateTime?

  // 確認當下凍結的該行債權總額快照（DRAFT 期間由明細即時加總，不存動態值）
  confirmedClaimAmount Decimal? @db.Decimal(21, 4)

  case      Case  @relation(fields: [caseId], references: [caseId], onDelete: Cascade)
  bank      Bank  @relation(fields: [bankCode], references: [bankCode])
  confirmer User? @relation("ParticipantConfirmedBy", fields: [confirmedBy], references: [userId])

  items       CreditItem[]
  allocations RepaymentAllocation[]

  @@unique([caseId, bankCode])
  @@index([bankCode])
  @@index([confirmationStatus])
  @@map("case_participant_banks")
}

/// 債權明細（掛在參與行下）；不存加總欄位，externalTotal 由四分項即時計算
model CreditItem {
  itemId        String    @id @default(cuid())
  participantId String
  claimType     ClaimType
  principal     Decimal   @default(0) @db.Decimal(21, 4) // 本金
  interest      Decimal   @default(0) @db.Decimal(21, 4) // 利息
  penalty       Decimal   @default(0) @db.Decimal(21, 4) // 違約金
  otherFee      Decimal   @default(0) @db.Decimal(21, 4) // 其他費用
  // externalTotal = principal+interest+penalty+otherFee（讀取即算，不落地）
  internalTotal Decimal   @default(0) @db.Decimal(21, 4) // 銀行內部帳列（可視性方案B，僅 PLATFORM_AUDITOR）
  note          String?

  participant CaseParticipantBank @relation(fields: [participantId], references: [participantId], onDelete: Cascade)

  @@index([participantId])
  @@map("credit_items")
}

// ============================== 還款 ==============================

/// 每期還款（每案×每期一筆）：最大債權行輸入該期實收總額
model RepaymentPeriod {
  periodId            String   @id @default(cuid())
  caseId              String
  period              String // YYYY-MM
  actualReceivedTotal Decimal  @db.Decimal(21, 4) // 該期實際收到總額（主辦輸入）
  hasRoundingAdjust   Boolean  @default(false) // 是否發生尾差（前端提醒用）
  recordedBy          String
  recordedAt          DateTime @default(now())
  note                String?

  case     Case @relation(fields: [caseId], references: [caseId], onDelete: Cascade)
  recorder User @relation("RepaymentRecordedBy", fields: [recordedBy], references: [userId])

  allocations RepaymentAllocation[]

  @@unique([caseId, period])
  @@index([caseId])
  @@map("repayment_periods")
}

/// 每期攤提到各行：原定應還 vs 實際攤得；尾差由主辦吸收
model RepaymentAllocation {
  allocationId       String  @id @default(cuid())
  periodId           String
  participantId      String
  plannedAmount      Decimal @default(0) @db.Decimal(21, 4) // 原定應還＝monthlyInstallment×planRatio
  actualAmount       Decimal @default(0) @db.Decimal(21, 4) // 實際攤得＝實收總額×planRatio（主辦含尾差）
  roundingAdjustment Decimal @default(0) @db.Decimal(21, 4) // 尾差調整（僅主辦列非 0）

  period      RepaymentPeriod     @relation(fields: [periodId], references: [periodId], onDelete: Cascade)
  participant CaseParticipantBank @relation(fields: [participantId], references: [participantId], onDelete: Cascade)

  @@unique([periodId, participantId])
  @@index([participantId])
  @@map("repayment_allocations")
}

// ============================== 通知與稽核 ==============================

model Notification {
  notificationId String           @id @default(cuid())
  userId         String
  type           NotificationType
  relatedCaseId  String?
  message        String
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

/// 單一稽核表（append-only，含帳號/案件狀態變更所需的 from/to 結構欄位）
model AuditLog {
  logId      String          @id @default(cuid())
  userId     String?
  bankCode   String?
  actionType AuditActionType
  targetType String? // 例：CASE / USER / BANK / COURT
  targetId   String?
  fromStatus String?
  toStatus   String?
  detail     String? // 補充（可存 JSON 文字）
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime        @default(now())

  user User? @relation(fields: [userId], references: [userId])

  @@index([createdAt])
  @@index([userId])
  @@index([actionType])
  @@map("audit_logs")
}
